{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Elastigroup",
  "title": "Elastigroup",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "example": "abc123"
    },
    "name": {
      "type": "string",
      "example": "Example Title"
    },
    "description": {
      "type": "string",
      "example": "A sample description."
    },
    "region": {
      "type": "string",
      "example": "example_value"
    },
    "capacity": {
      "type": "object",
      "properties": {
        "target": {
          "type": "integer"
        },
        "minimum": {
          "type": "integer"
        },
        "maximum": {
          "type": "integer"
        }
      },
      "example": "example_value"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "example": "2026-01-15T10:30:00Z"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "example": "2026-01-15T10:30:00Z"
    }
  }
}